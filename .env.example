# Public example only.
# This file documents the shape of the environment variables used by the public
# examples in this repository. It is not a complete production env file.

TZ=America/New_York
BASE_PATH=/srv/homelab

# Public-facing hostnames used by the example Caddy and Compose files
PUBLIC_BASE_DOMAIN=example.com
AUTH_HOST=auth.example.com
HOME_HOST=home.example.com
GRAFANA_HOST=grafana.example.com
PROMETHEUS_HOST=prometheus.example.com
ALERTS_HOST=alerts.example.com
SECRETS_HOST=secrets.example.com
WAZUH_HOST=wazuh.example.com

# Reverse proxy / monitoring headers
BLACKBOX_TOKEN=replace-me

# Authelia
AUTHELIA_JWT_SECRET=replace-me
AUTHELIA_SESSION_SECRET=replace-me
AUTHELIA_STORAGE_ENCRYPTION_KEY=replace-me
AUTHELIA_DEFAULT_REDIRECTION_URL=https://home.example.com
AUTHELIA_SESSION_DOMAIN=example.com
AUTHELIA_IDENTITY_VALIDATION_RESET_PASSWORD_JWT_SECRET=replace-me

# SMTP placeholders for Authelia notifications
AUTHELIA_NOTIFIER_SMTP_ADDRESS=smtp://smtp.example.com:587
AUTHELIA_NOTIFIER_SMTP_SENDER=Homelab <homelab@example.com>
AUTHELIA_NOTIFIER_SMTP_USERNAME=mailer@example.com
AUTHELIA_NOTIFIER_SMTP_PASSWORD=replace-me

# Infisical bootstrap placeholders
INFISICAL_SITE_URL=https://secrets.example.com
INFISICAL_ENCRYPTION_KEY=replace-me
INFISICAL_AUTH_SECRET=replace-me
INFISICAL_POSTGRES_PASSWORD=replace-me
INFISICAL_REDIS_PASSWORD=replace-me
INFISICAL_PROJECT_ID=replace-me
INFISICAL_MACHINE_TOKEN=replace-me
INFISICAL_ENV=prod
INFISICAL_SECRET_PATH=/

# OpenTofu / Terraform placeholders
TF_VAR_cloudflare_api_token=replace-me
TF_VAR_cloudflare_zone_name=example.com
TF_VAR_cloudflare_account_id=replace-me
TF_VAR_tailscale_api_key=replace-me
TF_VAR_tailscale_tailnet=example.ts.net

# Notification placeholders
TELEGRAM_BOT_TOKEN=replace-me
TELEGRAM_CHAT_ID=000000000
