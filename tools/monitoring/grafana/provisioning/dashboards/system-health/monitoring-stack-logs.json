{
  "title": "Monitoring Stack Logs (Loki)",
  "tags": ["homelab", "logs", "monitoring"],
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "custom",
        "query": "grafana,loki,promtail,prometheus,alertmanager,cadvisor,blackbox-exporter",
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "current": {
          "text": "All",
          "value": ".*"
        }
      }
    ]
  },
  "panels": [
    {
      "type": "logs",
      "title": "Monitoring Logs",
      "id": 1,
      "datasource": "Loki",
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "{job=\"docker\", service=~\"$service\"}",
          "refId": "A"
        }
      ],
      "options": {
        "showLabels": true,
        "dedupStrategy": "none",
        "wrapLogMessage": true
      }
    },
    {
      "type": "logs",
      "title": "Errors (last 1h)",
      "id": 2,
      "datasource": "Loki",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 10
      },
      "interval": "1h",
      "targets": [
        {
          "expr": "{job=\"docker\", service=~\"$service\"} |= \"error\"",
          "refId": "A"
        }
      ],
      "options": {
        "showLabels": true,
        "wrapLogMessage": true
      }
    },
    {
      "type": "timeseries",
      "title": "Error rate (5m)",
      "id": 3,
      "datasource": "Loki",
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 0,
        "y": 18
      },
      "targets": [
        {
          "expr": "sum(rate({job=\"docker\", service=~\"$service\"} |= \"error\" [5m]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Log volume (5m)",
      "id": 4,
      "datasource": "Loki",
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 12,
        "y": 18
      },
      "targets": [
        {
          "expr": "sum(rate({job=\"docker\", service=~\"$service\"} [5m]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        }
      }
    }
  ]
}
