{
  "title": "Service Logs (Loki)",
  "tags": ["homelab", "logs"],
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "datasource": "Loki",
        "query": "label_values({job=\"docker\"}, service)",
        "refresh": 1,
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "sort": 1,
        "current": {
          "text": "All",
          "value": ".*"
        }
      },
      {
        "name": "container",
        "type": "query",
        "datasource": "Loki",
        "query": "label_values({job=\"docker\", service=~\"$service\"}, container)",
        "refresh": 1,
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "sort": 1,
        "current": {
          "text": "All",
          "value": ".*"
        }
      }
    ]
  },
  "panels": [
    {
      "type": "logs",
      "title": "Service Logs",
      "id": 1,
      "datasource": "Loki",
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "{job=\"docker\", service=~\"$service\", container=~\"$container\"}",
          "refId": "A"
        }
      ],
      "options": {
        "showLabels": true,
        "dedupStrategy": "none",
        "wrapLogMessage": true
      }
    },
    {
      "type": "logs",
      "title": "Errors (last 1h)",
      "id": 2,
      "datasource": "Loki",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 10
      },
      "interval": "1h",
      "targets": [
        {
          "expr": "{job=\"docker\", service=~\"$service\", container=~\"$container\"} |= \"error\"",
          "refId": "A"
        }
      ],
      "options": {
        "showLabels": true,
        "wrapLogMessage": true
      }
    },
    {
      "type": "timeseries",
      "title": "Error rate (5m)",
      "id": 3,
      "datasource": "Loki",
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 0,
        "y": 18
      },
      "targets": [
        {
          "expr": "sum(rate({job=\"docker\", service=~\"$service\", container=~\"$container\"} |= \"error\" [5m]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Log volume (5m)",
      "id": 4,
      "datasource": "Loki",
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 12,
        "y": 18
      },
      "targets": [
        {
          "expr": "sum(rate({job=\"docker\", service=~\"$service\", container=~\"$container\"} [5m]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        }
      }
    }
  ]
}
