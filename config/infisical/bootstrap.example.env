# Example bootstrap file for a self-hosted Infisical deployment.
# Real values should be generated locally and kept out of version control.

POSTGRES_PASSWORD=replace-me
INFISICAL_POSTGRES_PASSWORD=replace-me
INFISICAL_REDIS_PASSWORD=replace-me
ENCRYPTION_KEY=replace-me
AUTH_SECRET=replace-me
SITE_URL=https://secrets.example.com
DB_CONNECTION_URI=postgresql://infisical:replace-me@infisical-postgres:5432/infisical
REDIS_URL=redis://:replace-me@infisical-redis:6379
TELEMETRY_ENABLED=false
